# ─── Discord ────────────────────────────────────────────────────────────────
# Bot token — from the "Bot" tab in the Discord Developer Portal
DISCORD_TOKEN=
# Application ID of the bot (shown under "General Information")
DISCORD_CLIENT_ID=
# Guild ID for command registration during development (optional).
# When set, commands are registered instantly in this server.
# Leave empty to register as global commands (may take up to 1 hour to propagate).
DISCORD_DEV_GUILD_ID=

# ─── Database ────────────────────────────────────────────────────────────────
# SQLite file path used by Prisma
DATABASE_URL="file:./prisma/dev.db"

# ─── External APIs ───────────────────────────────────────────────────────────
# API-Sports key (https://www.api-football.com/) — required for the Football provider.
# Without this key the bot starts normally but the FOOTBALL sport is disabled.
API_SPORTS_KEY=
# HLTV scraper does not require an API key — reserved for future use.
HLTV_API_KEY=

# ─── Runtime ─────────────────────────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
