# ─── Discord ───────────────────────────────────────────────
# Token gerado em https://discord.com/developers/applications
DISCORD_TOKEN=
# Client ID do bot (application ID)
DISCORD_CLIENT_ID=
# Guild ID para registro de comandos durante desenvolvimento (opcional; vazio = comandos globais)
DISCORD_DEV_GUILD_ID=

# ─── Database ──────────────────────────────────────────────
# Caminho do SQLite via Prisma
DATABASE_URL="file:./prisma/dev.db"

# ─── External APIs ─────────────────────────────────────────
# API-Sports (https://www.api-football.com/)
API_SPORTS_KEY=
# HLTV scraper geralmente não exige chave; reservado para futuro uso.
HLTV_API_KEY=

# ─── Runtime ───────────────────────────────────────────────
NODE_ENV=development
LOG_LEVEL=info
